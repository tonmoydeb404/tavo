{
  "name": "browser-extension-template",
  "version": "1.1.3",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "clean:workspace": "bash ./scripts/clean-workspace.sh",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "release:tag": "node ./scripts/release-tag-sync.mjs"
  },
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "knip": "^6.27.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.15",
    "typescript": "^5"
  },
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": ">=20"
  }
}
